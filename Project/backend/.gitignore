# backend/.gitignore

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environment (inside backend/)
venv/
.venv/
env/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Temporary / editor files
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db
.idea/
.vscode/

# Secrets
.env
*.env
secrets.yaml
