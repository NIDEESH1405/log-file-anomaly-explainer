# ============================================================
# Log File Anomaly Explainer — .gitignore
# ============================================================

# ── Secrets — NEVER commit these ────────────────────────────
.env
.envrc
*.env
secrets.yaml
secrets.json

# ── Python bytecode & caches ─────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# ── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
backend/venv/
.pixi/
__pypackages__/

# ── Distribution / packaging ─────────────────────────────────
build/
dist/
develop-eggs/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
.installed.cfg
lib/
lib64/
wheels/
share/python-wheels/
sdkit/

# ── Runtime-generated project files ──────────────────────────
# SQLite database (recreated on first run)
database.db
*.db
*.db-journal

# Uploaded log files (user data — not source code)
uploads/

# Generated reports (outputs — not source code)
reports/

# ── Temporary / personal files ───────────────────────────────
Resume.pdf
*.pdf
*.tmp
*.bak
*.swp
tempCodeRunnerFile.py

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.spyderproject
.spyproject
.ropeproject

# ── Testing & coverage ───────────────────────────────────────
.pytest_cache/
.cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py.cover
nosetests.xml
.hypothesis/

# ── Packaging tools ──────────────────────────────────────────
pip-log.txt
pip-delete-this-directory.txt
.pdm-python
.pdm-build/
.pypirc
.pybuilder/
target/

# ── Jupyter / IPython ────────────────────────────────────────
.ipynb_checkpoints
profile_default/
ipython_config.py

# ── Docs ─────────────────────────────────────────────────────
docs/_build/
/site

# ── Streamlit ────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Translations ─────────────────────────────────────────────
*.mo
*.pot
